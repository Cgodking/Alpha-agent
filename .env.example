# Copy to .env and fill secrets locally. Do not commit .env.

# AI candidate generation.
AI_CLIENT=multi
AI_API_KEY=your_key_here
# Accepts either https://your-relay.example/v1 or https://your-relay.example/v1/chat/completions
AI_BASE_URL=https://api.1314mc.net/v1
# Single-model fallback when AI_CLIENT=openai.
AI_MODEL=gpt-5.4-nano
# Multi-model orchestrated mode. Compact format uses the shared AI_API_KEY/AI_BASE_URL above.
AI_MODEL_PROFILES=grok-4-1-fast-reasoning@controller,deepseek-v4-pro-free@critic,gemini-3-flash-free@generator,glm-4.5@optimizer,gpt-5.4-nano@validator
# For separate provider keys/URLs, prefer a JSON profile file:
# AI_MODEL_PROFILES_FILE=config/ai_model_profiles.json
# Copy config/ai_model_profiles.example.json to config/ai_model_profiles.json, then copy
# secrets/ai/*.env.example to secrets/ai/*.env and put one relay token in each file.
# Each JSON entry may use env_file, api_key_env/base_url_env, or literal api_key/base_url.
# Optional per-model request_timeout limits slow/free routes.

# BRAIN integration.
# Keep local for AI-only dry runs. Use http for live BRAIN simulation/checks.
BRAIN_CLIENT=local
BRAIN_EMAIL=
BRAIN_PASSWORD=
BRAIN_BASE_URL=https://api.worldquantbrain.com
BRAIN_DATAFIELD_RETRIES=2

# Safety gates.
AUTO_SUBMIT=false
MAX_FINAL_SUBMITS_PER_ROUND=4
MAX_RETRIES=3
MIN_SHARPE=1.58
MIN_FITNESS=1.0
MAX_CORRELATION=0.7

# Runtime.
ALPHA_DB=alpha.db
BATCH_SIZE=8
LOOP_SECONDS=60

# Datafield discovery.
ALPHA_FIELD_DISCOVERY=true
ALPHA_FIELD_LIMIT=120
ALPHA_FIELD_CACHE_TTL_SECONDS=86400
# Comma-separated BRAIN data-field search terms; empty uses a broad first page.
ALPHA_FIELD_SEARCHES=model,analyst,fundamental,pv,news,sentiment
