# 复制为 .env 后填写本地密钥。不要提交 .env。

# AI 候选生成。
AI_CLIENT=multi
AI_API_KEY=your_key_here
# 支持 https://your-relay.example/v1 或 https://your-relay.example/v1/chat/completions
AI_BASE_URL=https://api.1314mc.net/v1
# AI_CLIENT=openai 时使用的单模型 fallback。
AI_MODEL=gpt-5.4-nano
# 多模型协作模式。紧凑写法会共用上面的 AI_API_KEY/AI_BASE_URL。
AI_MODEL_PROFILES=grok-4-1-fast-reasoning@controller,deepseek-v4-pro-free@critic,gemini-3-flash-free@generator,glm-4.5@optimizer,gpt-5.4-nano@validator
# 每个模型使用独立 token/地址时，建议使用 JSON profile 文件：
# AI_MODEL_PROFILES_FILE=config/ai_model_profiles.json
# 先复制 config/ai_model_profiles.example.json 到 config/ai_model_profiles.json，
# 再复制 secrets/ai/*.env.example 到 secrets/ai/*.env，每个文件放一个中转 token。
# JSON 条目可以使用 env_file、api_key_env/base_url_env，也可以直接写 api_key/base_url。
# request_timeout 可选，用于限制慢速或免费线路的单模型请求耗时。

# BRAIN 接入。
# AI-only dry run 保持 local；真实 BRAIN 回测和检查使用 http。
BRAIN_CLIENT=local
BRAIN_EMAIL=
BRAIN_PASSWORD=
BRAIN_BASE_URL=https://api.worldquantbrain.com
BRAIN_DATAFIELD_RETRIES=2

# 安全阈值。
AUTO_SUBMIT=false
MAX_FINAL_SUBMITS_PER_ROUND=4
MAX_RETRIES=3
MIN_SHARPE=1.58
MIN_FITNESS=1.0
MAX_CORRELATION=0.7

# 运行参数。
ALPHA_DB=alpha.db
BATCH_SIZE=8
LOOP_SECONDS=60

# 字段发现。
ALPHA_FIELD_DISCOVERY=true
ALPHA_FIELD_LIMIT=120
ALPHA_FIELD_CACHE_TTL_SECONDS=86400
# BRAIN 字段搜索词，逗号分隔；留空会使用较宽泛的第一页结果。
ALPHA_FIELD_SEARCHES=model,analyst,fundamental,pv,news,sentiment
