# 复制为 .env 后填写本地密钥。不要提交 .env。

# AI 候选生成。
AI_CLIENT=multi
AI_API_KEY=your_key_here
# 支持 https://your-relay.example/v1 或 https://your-relay.example/v1/chat/completions
AI_BASE_URL=https://api.1314mc.net/v1
# AI_CLIENT=openai 时使用的单模型 fallback。
AI_MODEL=gpt-5.4-nano
# 多模型协作模式。紧凑写法会共用上面的 AI_API_KEY/AI_BASE_URL。
# 个人生产默认 lean：每轮只调用 1 个生成模型，跳过 controller/critic/AI validator，优先省 token。
AI_ORCHESTRATION_MODE=lean
AI_MAX_ACTIVE_GENERATORS=1
# 只有近阈值 deep repair 时临时启用更多生成模型。
AI_TARGETED_REPAIR_GENERATORS=2
AI_MODEL_PROFILES=grok-4-1-fast-reasoning@controller,gemini-3-flash-free@generator,glm-4.5@optimizer,gpt-5.4-nano@validator
# 需要深度协作时再打开：
# AI_ORCHESTRATION_MODE=deep
# AI_MAX_ACTIVE_GENERATORS=0
# AI_MODEL_PROFILES=grok-4-1-fast-reasoning@controller,deepseek-v4-pro-free@critic,gemini-3-flash-free@generator,glm-4.5@optimizer,gpt-5.4-nano@validator
# AI 生成超时后不 fallback、不烧模拟，daemon 冷却后继续下一轮。
AI_GENERATION_TIMEOUT_BACKOFF_SECONDS=600
# 每个模型使用独立 token/地址时，建议使用 JSON profile 文件：
# AI_MODEL_PROFILES_FILE=config/ai_model_profiles.json
# 先复制 config/ai_model_profiles.example.json 到 config/ai_model_profiles.json，
# 再复制 secrets/ai/*.env.example 到 secrets/ai/*.env，每个文件放一个中转 token。
# JSON 条目可以使用 env_file、api_key_env/base_url_env，也可以直接写 api_key/base_url。
# request_timeout 可选，用于限制慢速或免费线路的单模型请求耗时。

# BRAIN 接入。
# AI-only dry run 保持 local；真实 BRAIN 回测和检查使用 http。
BRAIN_CLIENT=local
BRAIN_EMAIL=
BRAIN_PASSWORD=
BRAIN_BASE_URL=https://api.worldquantbrain.com
BRAIN_POLL_ATTEMPTS=180
BRAIN_INITIAL_POLL_ATTEMPTS=3
BRAIN_RESUME_POLL_ATTEMPTS=3
BRAIN_DATAFIELD_RETRIES=2
PENDING_RECHECK_COOLDOWN_SECONDS=900

# 安全阈值。
AUTO_SUBMIT=false
MAX_FINAL_SUBMITS_PER_ROUND=4
MAX_RETRIES=3
MIN_SHARPE=1.58
MIN_FITNESS=1.0
MAX_CORRELATION=0.7

# 运行参数。
ALPHA_DB=alpha.db
BATCH_SIZE=8
LOOP_SECONDS=60

# 字段发现。
ALPHA_FIELD_DISCOVERY=true
ALPHA_FIELD_LIMIT=1200
ALPHA_FIELD_CACHE_TTL_SECONDS=86400
# BRAIN 字段搜索词，逗号分隔；把 MODEL/PV 放后面，避免已点亮塔挤占新字段池。
ALPHA_FIELD_SEARCHES=option,risk,shortinterest,short interest,earnings,fundamental,news,analyst,sentiment,social,insider,institution,macro,other,quality,debt,tax,cashflow,model,pv,

# Web 控制台。默认只绑 127.0.0.1（回环）。
# 手机/局域网访问：设 ALPHA_WEB_HOST=0.0.0.0。
# 绑非回环地址却不设 token 会打印 warning，但仍允许启动，方便个人使用。
# 如需鉴权，可设置 ALPHA_WEB_TOKEN；手机用带 ?token=<token> 的链接打开控制台。
# 请求也支持 X-Alpha-Token 头。
# 状态变更接口还会做同源(Origin/Referer)校验。
# ALPHA_WEB_HOST=0.0.0.0
# ALPHA_WEB_PORT=8080
# ALPHA_WEB_TOKEN=set_a_long_random_token_here
